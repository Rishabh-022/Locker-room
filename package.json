{
  "name": "locker-room",
  "version": "1.0.0",
  "description": "Secure digital vault - Password Manager with Dual-Vault Security",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "author": "Ansh",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.ansh.lockerroom",
    "productName": "Locker Room",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Locker Room"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules/electron",
      "!node_modules/electron-builder"
    ]
  }
}
